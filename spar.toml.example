# Copy to spar.toml in a project, or ~/.config/spar/config.toml

max_agents = 4
default_backend = "auto" # auto | headless | tmux (native-cli spawn mode)
isolation = "worktree"   # none | worktree | worktree+db | worktree+bwrap
# autonomy: manual | semi | high | full  (recommended: semi or high)
autonomy = "semi"
message_budget = "normal" # none | lean | normal | chatty
auto_cleanup = false

[providers]
# Mix CLI + API: "cli:claude", "cli:grok", "api:openai", "api:xai", ...
order = ["cli:claude", "cli:grok", "cli:agy"]

[gates]
plan = true
winner = true
ship = true

[ship]
auto_confirm = false

[timeouts]
slot_secs = 1800
# review_secs = 1800   # optional; defaults to slot_secs (diff-focused, no full suites)
stall_warn_secs = 300  # running + no log output for this long ⇒ stalled in status/TUI (0 = off)
wait = "2h"

# Provider assignment by role. Values are @model-capable provider refs (cli:name / api:name).
# `reviewer` is a list (the review fleet). Distinct from [model_select.role_profiles] below,
# which picks a benchmark *profile* per role, not a provider.
# Precedence: explicit --providers (positional) > [roles] > [providers].order. A populated
# [roles] block satisfies the "--providers or --select is required" rule on its own, so
# `spar plan`/`implement` can run with no --providers at all.
[roles]
# planner = "cli:claude"
# plan_critic = "cli:grok"
# implementer = "cli:codex@anthropic/claude-opus-4.5"
# reviewer = ["cli:grok", "cli:agy", "cli:claude"]
# tester = "cli:agy"          # cheap suite runner (was [suite].provider)
# test_author = "cli:grok"    # pre-coding test author (was [spec].provider)

# Full test suite channel (cheap/dumb model). Implementers/reviewers must not run multi-hour suites.
[suite]
enabled = true
timeout_secs = 7200

# Reviewer verdict / acceptance gate. Review timeouts live under [timeouts].
[review]
# An `unverified` acceptance criterion blocks the ship like a `fail`. A criterion the
# reviewer never mentioned always blocks, regardless of this setting.
require_all_criteria = true

# Pre-coding acceptance tests (plan flow). Separate agent freezes tests before implement.
[spec]
enabled = true
timeout_secs = 1800

# Dynamic model select from vals.ai (opt-in via --select). See `spar model list|pick|refresh`.
[model_select]
# source = "vals"
# Multiple benches → metrics averaged for shared model ids (primary = first).
# benches = ["swebench", "terminal-bench-2-1"]
# cache_ttl_secs = 86400
# allow = ["cli:*", "api:openai", "api:xai"]
# [model_select.profiles.value]
# quality = 0.6
# cost = 0.8
# speed = 0.3
# min_accuracy = 70
# [model_select.role_profiles]   # role → benchmark profile (NOT provider; see [roles] above)
# planner = "best"
# plan_critic = "best"
# implementer = "value"
# reviewer = "value"
# tester = "fast"
# test_author = "fast"
